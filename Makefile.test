		 	ft_lstmap_bonus.c			\
		 	ft_lstnew_bonus.c			\
		 	ft_lstsize_bonus.c

MAIN	=	test/main.c								\
			test/utils_main.c						\
			test/test_1.c							\
			test/man-aux/strlcpy.c					\
			test/man-aux/strlcat.c					\
			test/man-aux/strnstr.c					\
			test/srcs/test_man_functions.c			\
			test/test_2.c							\
			test/srcs/test_aditionals_functions.c

OBJS	=	${SRCS:.c=.o}
OBJS_B	=	${SRCS_B:.c=.o}
OBJS_M	=	${MAIN:.c=.o}
DEPS	=	${SRCS:.c=.d} ${SRCS_B:.c=.d} ${MAIN:.c=.d}

# **************************************************************************** #
#                                 VARIABLES                                    #
# **************************************************************************** #

#Nombre del Programa
NAME		=	libft.a

#Tester del Programa
TEST		=	test_libft

#Flags de compilacion
FLAGS		=	-Wall -Werror -Wextra -I. 
DEPFLAGS	=	-MMD -MP

# **************************************************************************** #
#                                 RULES                                        #
# **************************************************************************** #

all:	${NAME} ${TEST}

%.o: %.c
	@echo "(пЊЙвЧХгГЃвЧХ)пЊЙ*:гГїпЊЯвЬІ Compilando $<, espere unos segundos..."
	cc ${FLAGS} ${DEPFLAGS} -c -o $@ $<
	@echo "(вАҐћАбіЧвАҐћБ)ўИ $@ generado!"

$(NAME):	${OBJS}
	@echo	"(пЊЙвЧХгГЃвЧХ)пЊЙ*:гГїпЊЯвЬІ Creando libreria, espere unos segundos..."
	ar -rcs ${NAME} ${OBJS}
	@echo	"(вАҐћАбіЧвАҐћБ)ўИ ${NAME} generado!"

bonus:		${OBJS_B}
	@echo	"(пЊЙвЧХгГЃвЧХ)пЊЙ*:гГїпЊЯвЬІ Creando libreria bonus, espere unos segundos..."
	ar -rcs ${NAME} ${OBJS_B}
	@echo	"(вАҐћАбіЧвАҐћБ)ўИ ${NAME} generado!"

$(TEST): ${NAME} ${OBJS_M}
	@echo  "(пЊЙвЧХгГЃвЧХ)пЊЙ*:гГїпЊЯвЬІ Compilando el ejecutable ${TEST}..."
	cc ${FLAGS} -o ${TEST} ${OBJS_M} ${NAME}
	@echo  "(вАҐћАбіЧвАҐћБ)ўИ ${TEST} generado!"

clean:
	rm -f ${OBJS} ${OBJS_B} ${OBJS_M} ${DEPS}
	@echo	"¬ѓ\_(гГД)_/¬ѓ Objects removidos!"

fclean:		clean
	rm -f ${NAME} ${TEST}
	@echo	"(вХѓ¬∞вЦ°¬∞пЉЙвХѓпЄµ вФївФБвФї $(NAME) removido!"

re: fclean all

.PHONY: all clean fclean re bonus
